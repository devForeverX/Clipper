<Window x:Class="Clipper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:Clipper.Models"
        Title="Clipper by ForeverX"
        Width="620"
        Height="420"
        MinWidth="620"
        MinHeight="420"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A"
        Foreground="White"
        FontFamily="Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="Card" Color="#111827" />
        <SolidColorBrush x:Key="Card2" Color="#0B1220" />
        <SolidColorBrush x:Key="Accent" Color="#7C3AED" />
        <SolidColorBrush x:Key="TextMuted" Color="#A8B3C7" />
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Background" Value="#1F2937"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="14"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#0B1220"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#334155"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Margin="22"
                CornerRadius="26"
                Background="{StaticResource Card}"
                BorderThickness="1"
                BorderBrush="#233044"
                Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Clipper"
                               FontSize="32"
                               FontWeight="Bold" />
                    <TextBlock Text="Clipper by ForeverX"
                               Margin="0,6,0,0"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="14"/>
                </StackPanel>

                <Border Grid.Row="2"
                        Background="{StaticResource Card2}"
                        CornerRadius="18"
                        Padding="18">
                    <StackPanel>
                        <TextBlock Text="Clip-Dauer"
                                   FontSize="15"
                                   FontWeight="SemiBold" />
                        <ComboBox x:Name="DurationComboBox"
                                  Margin="0,10,0,0"
                                  Height="42"
                                  DisplayMemberPath="Display"/>
                        <TextBlock Text="F8 speichert den letzten Clip direkt nach Videos\Clipper."
                                   Margin="0,10,0,0"
                                   Foreground="{StaticResource TextMuted}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="4" Orientation="Horizontal">
                    <Button x:Name="ToggleButton"
                            Style="{StaticResource RoundedButton}"
                            Background="{StaticResource Accent}"
                            Click="ToggleButton_Click"
                            Content="Stop" />
                    <Button x:Name="OpenFolderButton"
                            Style="{StaticResource RoundedButton}"
                            Click="OpenFolderButton_Click"
                            Content="Ordner öffnen" />
                </StackPanel>

                <Border Grid.Row="6"
                        Background="{StaticResource Card2}"
                        CornerRadius="18"
                        Padding="18">
                    <StackPanel>
                        <TextBlock Text="Status"
                                   FontSize="15"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="StatusText"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="14" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
